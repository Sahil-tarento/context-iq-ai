{
  "name": "contextiq-vscode",
  "displayName": "ContextIQ",
  "description": "Enterprise AI Context Optimization - Zero Config",
  "version": "1.0.0",
  "publisher": "ContextIQ",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Machine Learning",
    "Other"
  ],
  "activationEvents": [
    "onCommand:contextiq.ask"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "contextiq.ask",
        "title": "ContextIQ: Ask AI (Zero Config)"
      },
      {
        "command": "contextiq.index",
        "title": "ContextIQ: Index Workspace"
      }
    ],
    "keybindings": [
      {
        "command": "contextiq.ask",
        "key": "ctrl+alt+c",
        "mac": "cmd+alt+c",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "install-ext": "code --install-extension contextiq-vscode-1.0.0.vsix"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3",
    "@vscode/vsce": "^2.19.0"
  },
  "dependencies": {
    "axios": "^1.4.0"
  }
}
